# ─── Playwright E2E — environment variables ───────────────────────────────────
# Copy this file to tests/.env and fill in real values before running locally.
# playwright.config.ts reads PLAYWRIGHT_BASE_URL and PLAYWRIGHT_API_URL.
# tests/helpers/constants.ts reads the credential variables below.
# Never commit tests/.env — it is already in .gitignore.

# ─── URLs ─────────────────────────────────────────────────────────────────────

# Frontend URL (Vite dev server or deployed preview)
PLAYWRIGHT_BASE_URL=http://localhost:5173

# Spring Boot API base URL
PLAYWRIGHT_API_URL=http://localhost:8080

# ─── Login credentials ────────────────────────────────────────────────────────

# Application owner (top-level platform admin)
OWNER_EMAIL=owner@myskoolz.com
OWNER_PASS=Owner@123

# Super admin (school-level super admin)
SUPERADMIN_EMAIL=superadmin@testschool.com
SUPERADMIN_PASS=SuperAdmin@123

# Admin
ADMIN_EMAIL=admin@testschool.com
ADMIN_PASS=Admin@123

# Teacher
TEACHER_EMAIL=teacher@testschool.com
TEACHER_PASS=Teacher@123

# Student — logs in with admission number, NOT email
STUDENT_ADMISSION=S001
STUDENT_PASS=Student@123
