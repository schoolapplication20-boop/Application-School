# ─── Playwright E2E — environment variables ───────────────────────────────────
# Copy this file to tests/.env (already in .gitignore).
# Defaults below match the "My Skoolz" test school (ID 9999).
# Run tests/seed/seed.mjs once to create that school before testing.

# ─── URLs ─────────────────────────────────────────────────────────────────────

# Frontend URL (Vite dev server or Vercel preview)
PLAYWRIGHT_BASE_URL=http://localhost:5173

# Spring Boot API base URL
PLAYWRIGHT_API_URL=http://localhost:8080

# ─── Credentials (My Skoolz test school, ID 9999) ─────────────────────────────

OWNER_EMAIL=owner@myskoolz.com
OWNER_PASS=Owner@123

SUPERADMIN_EMAIL=superadmin@myskoolz.test
SUPERADMIN_PASS=Skoolz@SuperAdmin1

ADMIN_EMAIL=admin@myskoolz.test
ADMIN_PASS=Skoolz@Admin1

TEACHER_EMAIL=teacher1@myskoolz.test
TEACHER_PASS=Skoolz@Teacher1

# Students log in with admission number (not email)
STUDENT_ADMISSION=MSZ001
STUDENT_PASS=Skoolz@Student1
