# Copy this file to .env.local for local development
# .env.local is gitignored — never commit real values

# ── Backend API (required) ────────────────────────────────────────────────────
# Local:      http://localhost:8080
# Production: https://your-backend.up.railway.app  (or Render/AWS/etc.)
VITE_API_URL=http://localhost:8080

# ── App metadata (optional) ──────────────────────────────────────────────────
# Overrides the default "My-Skoolz" branding in the browser tab
VITE_APP_NAME=My-Skoolz

# ── Feature flags (optional) ────────────────────────────────────────────────
# Set to "true" to enable WhatsApp integration
VITE_WHATSAPP_ENABLED=false

# ── WhatsApp Ordering Portal (optional) ─────────────────────────────────────
# URL for the standalone WhatsApp Ordering Portal SaaS product.
# The /whatsapp route in My-Skoolz redirects here.
# Local dev:   http://localhost:5174
# Production:  https://wop.my-skoolz.com  (or your Railway deploy URL)
VITE_WOP_URL=http://localhost:5174
