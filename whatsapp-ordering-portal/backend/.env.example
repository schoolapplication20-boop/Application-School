# ============================================
# WhatsApp Ordering Portal - Backend Environment
# ============================================

# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
# On Railway, attach the Postgres plugin and it provides DATABASE_URL automatically -
# leave the DB_* vars below unset and the app will use DATABASE_URL instead.
# DATABASE_URL=postgresql://user:password@host:port/database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=whatsapp_portal
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password
DB_SCHEMA=whatsapp_portal
# Set to "require" if your Postgres provider needs SSL (e.g. Railway public proxy, Supabase)
DB_SSL=

# Redis
# On Railway, attach the Redis plugin and it provides REDIS_URL automatically -
# leave the REDIS_* vars below unset and the app will use REDIS_URL instead.
# REDIS_URL=redis://default:password@host:port
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# JWT
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_at_least_32_characters_long
JWT_REFRESH_EXPIRE=30d

# Email/SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@whatsappportal.com
SMTP_FROM_NAME=WhatsApp Portal

# OTP
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_LOCKOUT_MINUTES=15

# WhatsApp Integration
WHATSAPP_API_PROVIDER=meta
WHATSAPP_GRAPH_API_VERSION=v21.0
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# File Storage
FILE_STORAGE_TYPE=local
FILE_UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# AWS S3 (if using S3)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BUCKET=whatsapp-portal-storage

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# Security
CORS_ORIGIN=http://localhost:5173
ALLOW_CREDENTIALS=true
ENCRYPTION_KEY=your_encryption_key_32_chars_min

# External Services
SENTRY_DSN=

# Payment Gateway (future)
PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Feature Flags
FEATURE_AI_CHAT=true
FEATURE_AUTOMATED_RESPONSES=true
FEATURE_INVENTORY_TRACKING=true
FEATURE_PAYMENT_INTEGRATION=false

# Monitoring
MONITORING_ENABLED=true
APM_ENABLED=false
APM_SERVER_URL=

# Testing
TEST_DB_NAME=whatsapp_portal_test
