# ============================================
# WhatsApp Ordering Portal - Frontend Environment
# ============================================

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_APP_NAME=WhatsApp Ordering Portal
VITE_APP_DESCRIPTION=SaaS Platform for WhatsApp-based Ordering

# Environment
VITE_ENV=development

# Feature Flags
VITE_FEATURE_AI_CHAT=true
VITE_FEATURE_ANALYTICS=true
VITE_FEATURE_INVENTORY=true
VITE_FEATURE_PAYMENTS=false

# Logging
VITE_LOG_LEVEL=debug

# Analytics (optional)
VITE_ANALYTICS_ID=
VITE_SENTRY_DSN=
