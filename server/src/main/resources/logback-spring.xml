<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
        Log format:
          default             → human-readable console output
          profile "json-log" → structured JSON — one line per event,
                               parseable by Railway / Datadog / Loki

        Activate JSON on Railway by setting:
          SPRING_PROFILES_ACTIVE=json-log

        The %X{requestId} token comes from RequestIdFilter's MDC entry.
        All log lines from the same HTTP request share the same requestId.
    -->

    <!-- ── Colour-coded console appender (development / default) ───────── -->
    <appender name="CONSOLE_TEXT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%X{requestId:--}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── Structured JSON console appender (production) ──────────────── -->
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>{"ts":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}","level":"%-5level","requestId":"%X{requestId:--}","logger":"%logger{36}","msg":"%replace(%msg){'\"','\\\"'}"}%n</pattern>
        </encoder>
    </appender>

    <!-- ── Default: text output ─────────────────────────────────────────── -->
    <springProfile name="!json-log">
        <root level="${LOG_LEVEL:-INFO}">
            <appender-ref ref="CONSOLE_TEXT"/>
        </root>
    </springProfile>

    <!-- ── json-log profile: structured JSON output ─────────────────────── -->
    <springProfile name="json-log">
        <root level="${LOG_LEVEL:-INFO}">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
    </springProfile>

    <!-- ── Per-package overrides ─────────────────────────────────────────── -->
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="com.zaxxer.hikari" level="WARN"/>

</configuration>
